{
  "name": "smeta-stroyka-ai-calculator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI calculator prototype for construction estimates, tenders, and commercial proposals.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "adapter:check": "tsx scripts/adapter-check.ts",
    "domain:check": "tsx scripts/domain-check.ts",
    "price-import:check": "tsx scripts/price-import-check.ts",
    "smoke": "node scripts/smoke.cjs",
    "check": "npm run price-import:check && npm run adapter:check && npm run domain:check && npm run typecheck && npm run lint && npm run format:check",
    "check:all": "npm run check && npm run smoke",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "format": "prettier \"src/**/*.{ts,tsx,md}\" \"scripts/**/*.{cjs,ts}\" \"*.{json,js}\" \".github/**/*.yml\" \"docs/ITERATION_*.md\" \"docs/ITERATION_REVIEW_*.md\" \"docs/CODEX_FAQ.md\" --write",
    "format:check": "prettier \"src/**/*.{ts,tsx,md}\" \"scripts/**/*.{cjs,ts}\" \"*.{json,js}\" \".github/**/*.yml\" \"docs/ITERATION_*.md\" \"docs/ITERATION_REVIEW_*.md\" \"docs/CODEX_FAQ.md\" --check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "eslint": "^10.4.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
